# R2 Configuration for OpenClaw Face
# Copy this file to .env and update with your actual URLs

# URL for status.json in your R2 bucket
VITE_R2_PUBLIC_URL=https://your-account-id.r2.cloudflarestorage.com/your-bucket-name/status.json

# URL for cost.json in your R2 bucket
VITE_R2_COST_URL=https://your-account-id.r2.cloudflarestorage.com/your-bucket-name/cost.json
